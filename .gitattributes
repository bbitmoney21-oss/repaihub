# Normalize line endings — root cause fix for the CRLF/LF noise that
# made the working tree show 128 modified files with zero functional diff.
# Working tree on Windows can stay CRLF, but what's stored in git is LF.

* text=auto eol=lf

# PowerShell scripts run on Windows — keep CRLF on disk and in repo.
*.ps1 text eol=crlf

# Explicit binaries — never line-ending convert.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.pdf binary
*.zip binary
*.gz  binary
*.tar binary
*.exe binary
*.bin binary
*.mp4 binary
*.mp3 binary
