{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist-server",
    "rootDir": "src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/server.ts",
    "src/types/**/*.ts",
    "src/data/**/*.ts",
    "src/middleware/**/*.ts",
    "src/routes/caPortal.ts"
  ],
  "exclude": [
    "src/pages",
    "src/components",
    "src/lib",
    "src/store",
    "src/main.tsx",
    "src/App.tsx"
  ]
}
