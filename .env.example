# REPAIHUB — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# For Render: set these under Dashboard → Environment → Environment Variables

PORT=3001
NODE_ENV=development

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_minimum_32_characters
CA_JWT_SECRET=your_ca_jwt_secret_minimum_32_characters
CA_EMAIL=ca@repaihub.com
CA_DEFAULT_PASSWORD=your_ca_portal_password
CA_ICAI=your_icai_number

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@repaihub.com

# ── App URLs ──────────────────────────────────────────────────────────────────
API_BASE_URL=https://repaihub.com
FRONTEND_URL=https://repaihub.com

# ── Payment Rails (leave blank for mock mode) ─────────────────────────────────
FABLE_API_KEY=
FABLE_API_URL=
FABLE_WEBHOOK_SECRET=

# ── KYC Providers (leave blank for mock mode) ─────────────────────────────────
FLINKS_CUSTOMER_ID=
SETU_API_KEY=
SETU_CLIENT_ID=

# ── RBI Compliance Rules ──────────────────────────────────────────────────────
# Change these in Render dashboard when RBI updates rules — no deployment needed
RBI_ANNUAL_LIMIT_INR=83000000
RBI_FORM145_THRESHOLD_INR=50000
RBI_FORM146_THRESHOLD_INR=500000
RBI_FAST_TRACK_MAX_INR=50000
RBI_TCS_THRESHOLD_INR=700000
RBI_FINTRAC_THRESHOLD_CAD=10000
RBI_MAX_SINGLE_TX_INR=8300000
RBI_FY_START_MONTH=3
RBI_PURPOSE_CODES_ENABLED=P0101,P0102,P0103,P1004,P0301
COMPLIANCE_RULES_VERSION=2026-04-01
